# EnerVision Environment Configuration

# ============================
# AI Service API Keys
# ============================
# Replace with your actual Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Replace with your AgentOps API key (for AI monitoring/agent tracing)
AGENTOPS_API_KEY=your_agentops_api_key_here

# Replace with your LangSmith API key (for LangChain tracing and evaluation)
LANGSMITH_API_KEY=your_langsmith_api_key_here


# ============================
# Gmail SMTP Configuration
# ============================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Replace with your Gmail address
SMTP_USERNAME=your_email@gmail.com

# Replace with your App Password (from Google Account > Security > App Passwords)
SMTP_PASSWORD=your_gmail_app_password_here

# Alternative providers (uncomment and modify if using Outlook/Yahoo):
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_HOST=smtp.mail.yahoo.com


# ============================
# EnerVision Settings
# ============================
APP_NAME=EnerVision Energy Management
DEBUG=False


# ============================
# Database Configuration (Production)
# ============================
# Replace with your PostgreSQL credentials and host
DATABASE_URL=postgresql://username:password@localhost:5432/enervision

# Redis connection URL for caching
REDIS_URL=redis://localhost:6379


# ============================
# Application Settings
# ============================
APP_NAME=EnerVision
APP_VERSION=1.0.0
DEBUG_MODE=False
LOG_LEVEL=INFO


# ============================
# Security
# ============================
# Replace these with securely generated keys (use `secrets.token_hex(32)` in Python)
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here


# ============================
# File Upload Settings
# ============================
MAX_FILE_SIZE=10MB
ALLOWED_EXTENSIONS=pdf,docx,txt,csv,json


# ============================
# Rate Limiting
# ============================
API_RATE_LIMIT=1000
CHAT_RATE_LIMIT=100


# ============================
# Monitoring
# ============================
ENABLE_MONITORING=True
HEALTH_CHECK_INTERVAL=60


# ============================
# RAG ChatBot Environment Configuration
# ============================

# Langfuse Tracing Configuration
# Replace with your Langfuse secret and public keys
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Replace with your LangChain API key if using LangSmith tracing
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=true

# Optional: specify custom embedding model for RAG
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG Configuration
CONFIDENCE_THRESHOLD=0.7
TOP_K_RESULTS=3
MAX_CHUNK_SIZE=512
